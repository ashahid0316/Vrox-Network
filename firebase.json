
{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/download",
        "destination": "/download/index.html"
      },
      {
        "source": "/knowledge-hub",
        "destination": "/knowledge-hub/index.html"
      },
      {
        "source": "/privacy-policy",
        "destination": "/privacy-policy/index.html"
      },
      {
        "source": "/support",
        "destination": "/support/index.html"
      },
      {
        "source": "/terms",
        "destination": "/terms/index.html"
      },
      {
        "source": "/updates",
        "destination": "/updates/index.html"
      },
      {
        "source": "/what-is-blockchain",
        "destination": "/what-is-blockchain/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          },
          {
            "key": "Content-Security-Policy",
            "value": "upgrade-insecure-requests"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/download.html",
        "destination": "/download/",
        "type": 301
      },
      {
        "source": "/knowledge-hub.html",
        "destination": "/knowledge-hub/",
        "type": 301
      },
      {
        "source": "/privacy-policy.html",
        "destination": "/privacy-policy/",
        "type": 301
      },
      {
        "source": "/support.html",
        "destination": "/support/",
        "type": 301
      },
      {
        "source": "/terms.html",
        "destination": "/terms/",
        "type": 301
      },
      {
        "source": "/updates.html",
        "destination": "/updates/",
        "type": 301
      },
      {
        "source": "/what-is-blockchain.html",
        "destination": "/what-is-blockchain/",
        "type": 301
      }
    ]
  }
}
